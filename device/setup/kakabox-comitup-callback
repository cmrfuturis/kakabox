#!/bin/bash
# Wird von comitup bei jedem State-Wechsel aufgerufen.
# Argument: HOTSPOT | CONNECTING | CONNECTED
#
# Verantwortung:
#   - Audio-Feedback zum WLAN-Status abspielen — aber nur dann, wenn der
#     Nutzer es wirklich braucht. Wenn die Box mit bekanntem WLAN bootet,
#     wechselt comitup kurz durch HOTSPOT bevor sie sich verbindet. Wir
#     wollen dann KEINEN "bitte verbinden"-Prompt — und auch kein "WLAN
#     verbunden", denn main.py spielt schon "Ready to rumble" beim Boot.
#
# Strategie:
#   - HOTSPOT: Prompt um 12s verzögern (Hintergrund). Wenn bis dahin
#     CONNECTING oder CONNECTED feuert, wird der pending-Prompt gecancelt.
#   - CONNECTED: nur dann "WLAN verbunden" abspielen, wenn vorher der
#     HOTSPOT-Prompt tatsächlich lief (= echter Onboarding-Flow, nicht
#     Auto-Connect beim Boot).
#
# Lautstärke: Prompts laufen auf system_volume aus config.json (separater
# Pegel für Boot/WLAN/Bye, normalerweise leiser als die Musik). Vor dem aplay
# wird ALSA-PCM auf system_volume gesetzt, danach auf die User-Lautstärke
# zurück — beide Werte werden frisch aus config gelesen, falls der User
# während der Ansage am Encoder gedreht hat.
#
# Abbruch per Knopfdruck: aplay-PID wird in $STATE_DIR/prompt_pid abgelegt;
# main.py liest die Datei beim Button-Press und schickt SIGTERM, womit die
# Wiedergabe direkt endet (siehe _kill_aplay_prompt in main.py).
#
# Wird aus /etc/comitup.conf via external_callback geladen.

set -u

STATE="${1:-}"
LOG=/var/log/kakabox-callback.log
PROMPTS=/usr/share/kakabox/prompts
STATE_DIR=/run/kakabox
CONFIG=/home/riffi/Dokumente/kakabox/device/config.json
HOTSPOT_DELAY=12

mkdir -p "$STATE_DIR"

log() { echo "$(date -Is) [$STATE] $*" >> "$LOG"; }

read_config_volume() {
    # Liest ein int-Feld aus config.json. Args: $1=key, $2=default.
    # Robust gegen fehlende Datei / kaputtes JSON.
    local key="$1" default="$2"
    python3 -c "
import json
try:
    v = json.load(open('$CONFIG')).get('$key')
    print(int(v) if v is not None else $default)
except Exception:
    print($default)
" 2>/dev/null || echo "$default"
}

set_alsa_volume() {
    # Card 0 + PCM-Control entsprechen dem, was main.py nutzt
    # (hardware/audio_output.py). Failsafe: bei Fehlern weiter, kein Abort.
    amixer -c 0 sset PCM "${1}%" >/dev/null 2>&1 || true
}

play_prompt() {
    local file="$PROMPTS/$1"
    [ -f "$file" ] || { log "prompt missing: $file"; return; }

    local sys_vol
    sys_vol=$(read_config_volume system_volume 60)
    set_alsa_volume "$sys_vol"
    log "Prompt-Lautstärke ALSA PCM auf ${sys_vol}% (system_volume)"

    # aplay im Hintergrund — PID merken, damit ein Knopfdruck via SIGTERM
    # die Wiedergabe abbrechen kann (siehe _kill_aplay_prompt in main.py).
    aplay -q -D plughw:CARD=sndrpigooglevoi,DEV=0 "$file" 2>&1 | tee -a "$LOG" &
    local pid=$!
    echo "$pid" > "$STATE_DIR/prompt_pid"
    wait "$pid" 2>/dev/null
    local rc=$?
    rm -f "$STATE_DIR/prompt_pid"
    log "aplay beendet (rc=$rc)"

    # ALSA zurück auf User-Lautstärke — frisch aus config, könnte sich
    # während der Ansage geändert haben.
    local user_vol
    user_vol=$(read_config_volume volume 70)
    set_alsa_volume "$user_vol"
}

cancel_pending_hotspot() {
    if [ -f "$STATE_DIR/hotspot_pid" ]; then
        local pid
        pid=$(cat "$STATE_DIR/hotspot_pid" 2>/dev/null || true)
        if [ -n "${pid:-}" ]; then
            kill "$pid" 2>/dev/null || true
        fi
        rm -f "$STATE_DIR/hotspot_pid"
    fi
    rm -f "$STATE_DIR/hotspot_pending"
}

case "$STATE" in
    HOTSPOT)
        # User-Reset (Rot 5s) hat vorher den Marker gesetzt — main.py spielt
        # die Reset-Ansage selbst und sofort, der 12s-Callback-Prompt würde
        # nur kollidieren. hotspot_announced wird gesetzt, damit beim späteren
        # CONNECTED-Übergang die "WLAN verbunden"-Ansage normal kommt.
        if [ -f "$STATE_DIR/skip_hotspot_prompt" ]; then
            log "Hotspot-Modus aktiv — User-Reset erkannt, Callback-Prompt übersprungen"
            rm -f "$STATE_DIR/skip_hotspot_prompt"
            cancel_pending_hotspot
            touch "$STATE_DIR/hotspot_announced"
        else
            log "Hotspot-Modus aktiv — Setup-Ansage in ${HOTSPOT_DELAY}s (falls wir bis dahin nicht verbunden sind)"
            # Vorherige State-Marker putzen — neuer HOTSPOT-Zyklus
            rm -f "$STATE_DIR/hotspot_announced"
            cancel_pending_hotspot
            touch "$STATE_DIR/hotspot_pending"
            (
                sleep "$HOTSPOT_DELAY"
                # Marker noch da? Dann waren wir die ganze Zeit im Hotspot.
                if [ -f "$STATE_DIR/hotspot_pending" ]; then
                    rm -f "$STATE_DIR/hotspot_pending" "$STATE_DIR/hotspot_pid"
                    touch "$STATE_DIR/hotspot_announced"
                    play_prompt setup_active.wav
                fi
            ) &
            echo $! > "$STATE_DIR/hotspot_pid"
        fi
        ;;
    CONNECTING)
        log "Verbindungsversuch — pending Hotspot-Prompt verwerfen"
        cancel_pending_hotspot
        ;;
    CONNECTED)
        log "Mit Heim-WLAN verbunden"
        cancel_pending_hotspot
        if [ -f "$STATE_DIR/hotspot_announced" ]; then
            rm -f "$STATE_DIR/hotspot_announced"
            play_prompt wifi_connected.wav
        else
            log "Auto-Connect ohne vorherigen Hotspot-Prompt — keine Ansage"
        fi
        ;;
    *)
        log "Unbekannter State: $STATE"
        ;;
esac
