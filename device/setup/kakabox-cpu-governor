#!/bin/bash
# Setzt den CPU-Governor — von main.py via sudo aufgerufen, um im Standby Strom
# zu sparen (powersave), beim Aufwecken reaktiv zu sein (ondemand) und während
# der latenzkritischen Voice-Erkennung volle Taktrate ohne Ramp-up zu haben
# (performance, nur für die Dauer des Voice-Flows — ASR-Plan 2026-07-07, 1.2).
# Der sudoers-Drop-in erlaubt dem Box-User NOPASSWD NUR für genau diese Argumente.
set -u

GOV="${1:-}"
case "$GOV" in
    powersave|ondemand|performance) ;;
    *) echo "usage: $0 powersave|ondemand|performance" >&2; exit 2 ;;
esac

for g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
    [ -w "$g" ] && echo "$GOV" > "$g"
done
