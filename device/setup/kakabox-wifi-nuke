#!/bin/bash
# Löscht alle WLAN-Profile und rebootet.
# Wird von main.py via sudo aufgerufen, wenn der rote Knopf 10s gehalten wird.
# Sudoers-Drop-in (siehe install-wifi-onboarding.sh) erlaubt riffi NOPASSWD nur
# für genau diesen Pfad.
set -u

LOG=/var/log/kakabox-wifi-nuke.log
echo "$(date -Is) WiFi-Nuke wurde ausgelöst" >> "$LOG"

# Alle WLAN-Profile aus NetworkManager entfernen
nmcli -t -f TYPE,UUID connection show 2>/dev/null \
| awk -F: '$1=="802-11-wireless"{print $2}' \
| while read -r uuid; do
    echo "$(date -Is) delete uuid=$uuid" >> "$LOG"
    nmcli connection delete "$uuid" >> "$LOG" 2>&1 || true
done

echo "$(date -Is) reboot now" >> "$LOG"
sync
exec systemctl reboot
