# Erlaubt main.py (User riffi) zwei Hardware-Aktionen ohne Passwort.
# Sehr eng eingegrenzt: NUR diese zwei festen Pfade ohne Argumente.
# Wird vom Installer nach /etc/sudoers.d/kakabox installiert.
riffi ALL=(root) NOPASSWD: /usr/local/bin/kakabox-poweroff
riffi ALL=(root) NOPASSWD: /usr/local/bin/kakabox-wifi-clear
# CPU-Governor fürs Standby-Energiesparen — nur die zwei festen Argumente.
riffi ALL=(root) NOPASSWD: /usr/local/bin/kakabox-cpu-governor powersave
riffi ALL=(root) NOPASSWD: /usr/local/bin/kakabox-cpu-governor ondemand
