# Erlaubt main.py (Box-User) ein paar Hardware-Aktionen ohne Passwort.
# Sehr eng eingegrenzt: NUR diese festen Pfade mit festen Argumenten.
# TEMPLATE — __RUN_USER__ wird vom Installer (render()) durch den echten
# Box-User ersetzt, bevor die Datei nach /etc/sudoers.d/kakabox installiert wird.
__RUN_USER__ ALL=(root) NOPASSWD: /usr/local/bin/kakabox-poweroff
__RUN_USER__ ALL=(root) NOPASSWD: /usr/local/bin/kakabox-wifi-clear
# CPU-Governor fürs Standby-Energiesparen + Voice-Boost — nur die drei festen Argumente.
__RUN_USER__ ALL=(root) NOPASSWD: /usr/local/bin/kakabox-cpu-governor powersave
__RUN_USER__ ALL=(root) NOPASSWD: /usr/local/bin/kakabox-cpu-governor ondemand
__RUN_USER__ ALL=(root) NOPASSWD: /usr/local/bin/kakabox-cpu-governor performance
